{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/((?!assets/|favicon|robots|manifest|logo|.*\\.(?:png|jpg|jpeg|svg|webp|ico|json|txt|xml|js|css|woff|woff2|ttf|eot)$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
