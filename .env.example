# Convex deployment (auto-provisioned by `npx convex dev`)
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# Better Auth
# Génère un secret avec : openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL publique du site (sans trailing slash). Dev : http://localhost:3000
SITE_URL=http://localhost:3000
VITE_SITE_URL=http://localhost:3000

# Mode de l'app : "prod" (default) ou "demo" (subdomain démo gelé)
# VITE_APP_MODE=prod
